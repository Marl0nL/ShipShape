# ShipShape control-plane configuration — TEMPLATE.
#
# On first run the control plane copies this to `shipshape.toml` (gitignored — your
# live, local config). Fill in your values there; they stay out of git.
# Overridable with env: $SHIPSHAPE_AGENT_SA, $SHIPSHAPE_AGENT_CONTAINER.

[gcp]
# Dedicated, scope-limited service account the control plane mints keys for.
# Create it once and grant your user roles/iam.serviceAccountKeyAdmin on it
# (see docs/DESIGN.md → "Operator one-time GCP setup"), then put its email here, e.g.
#   agent_sa = "agent-daily@YOUR_GCP_PROJECT.iam.gserviceaccount.com"
agent_sa = ""

# The agent container name — must match docker-compose.yml `container_name`.
agent_container = "agent-sandbox"

[commands]
# Working directory for operator-approved agent commands (run on the host as you).
# Default: the repo root. Uncomment to override.
# cwd = "/path/to/your/project"

# Extra components for the provision wizard (builtin: flutter, adb). Each maps to
# an install command available in the container plus the egress domains it needs.
# [components.node]
# install = "install-node"          # add a matching script to agent-bin/
# domains = ["deb.nodesource.com"]
# check = "node --version"
# description = "Node.js"
