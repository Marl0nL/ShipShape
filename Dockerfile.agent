# Use a slim Python base image to save space, but with Debian under the hood
FROM python:3.11-slim-bullseye

# Avoid user interaction during apt installations
ENV DEBIAN_FRONTEND=noninteractive

# 1. Install system dependencies for Flutter, gcloud, and gh
RUN apt-get update && apt-get install -y \
    curl git unzip xz-utils zip libglu1-mesa wget gnupg software-properties-common \
    && rm -rf /var/lib/apt/lists/*

# 2. Install Google Cloud CLI
# (apt-key is deprecated; dearmor the key into a dedicated keyring instead, and
#  use `>` rather than `tee -a` so rebuilds don't append duplicate repo lines.)
RUN echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main" > /etc/apt/sources.list.d/google-cloud-sdk.list && \
    curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg | gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg && \
    apt-get update && apt-get install -y google-cloud-cli && \
    rm -rf /var/lib/apt/lists/*

# 3. Install GitHub CLI (gh)
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
    apt-get update && apt-get install -y gh && \
    rm -rf /var/lib/apt/lists/*

# 4. Create a non-root user for the agent to run as
RUN useradd -ms /bin/bash agentdev
USER agentdev
WORKDIR /home/agentdev

# 5. Install Flutter (as the non-root user)
RUN git clone https://github.com/flutter/flutter.git -b stable /home/agentdev/flutter
ENV PATH="/home/agentdev/flutter/bin:${PATH}"
# Run flutter doctor to pre-download Dart SDK and toolchains
RUN flutter doctor

# 6. Set up the Python environment (optional, but good practice)
COPY --chown=agentdev:agentdev requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Keep the container alive for firstmate to orchestrate
CMD ["tail", "-f", "/dev/null"]
