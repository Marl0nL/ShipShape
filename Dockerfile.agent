# ShipShape agent image — firstmate-ready.
#
# The base still installs on-demand for project dev stacks (Flutter/adb via the
# install-* skills), but the firstmate orchestration toolchain + coding-agent CLIs
# the user asked for are baked in: tmux, herdr, node, jq, gh, the Claude Code CLI,
# the Antigravity CLI, and a clone of the user's firstmate fork.
#
# "Best-effort" installs (herdr, antigravity, treehouse/no-mistakes, *-axi) are
# tolerant (|| true) so one flaky upstream installer can't break the whole image;
# check the build log for any that warned. Reproducible pinning of those is future
# work. This image MUST be built + smoke-tested live (many network installs).
# Debian 12 (bookworm) — glibc 2.36. Bullseye's glibc 2.31 is too old for modern
# Go release binaries (treehouse needs GLIBC_2.34+), so bookworm is required.
FROM python:3.11-slim-bookworm@sha256:f5cf0344c9886ff24d34797578d5d7dd6e8911ae0fe5962bb55d0f89603ec361

ENV DEBIAN_FRONTEND=noninteractive
# User-installed CLIs (claude, herdr, agy, treehouse, no-mistakes, npm globals) land here.
ENV PATH="/home/agentdev/.local/bin:${PATH}"

# 1. System tooling: bootstrap essentials + firstmate deps (tmux/jq), all baked.
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git unzip xz-utils gnupg tmux jq procps \
    && rm -rf /var/lib/apt/lists/*

# 1b. Node.js (firstmate + the *-axi tooling need it) via NodeSource.
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# 2. Google Cloud CLI (the auth flow activates the injected SA key on start).
RUN echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main" > /etc/apt/sources.list.d/google-cloud-sdk.list && \
    curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg | gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg && \
    apt-get update && apt-get install -y --no-install-recommends google-cloud-cli && \
    rm -rf /var/lib/apt/lists/*

# 3. GitHub CLI (gh)
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && apt-get install -y --no-install-recommends gh && \
    rm -rf /var/lib/apt/lists/*

# 3b. File-based GitHub auth glue so a rotated /auth/gh-token is picked up LIVE.
RUN printf '%s\n' '#!/bin/sh' \
      'if [ -r /auth/gh-token ]; then GH_TOKEN="$(cat /auth/gh-token)"; export GH_TOKEN; fi' \
      'exec /usr/bin/gh "$@"' > /usr/local/bin/gh && \
    chmod +x /usr/local/bin/gh && \
    git config --system credential."https://github.com".helper \
      '!f() { echo username=x-access-token; echo "password=$(cat /auth/gh-token 2>/dev/null)"; }; f'

# 3c. Entrypoint: activate the injected GCP SA key on start (serves gcloud + ADC).
RUN printf '%s\n' '#!/bin/sh' \
      'if [ -r /auth/gcp-sa.json ]; then' \
      '  gcloud auth activate-service-account --key-file=/auth/gcp-sa.json >/dev/null 2>&1 || true' \
      'fi' \
      'exec "$@"' > /usr/local/bin/agent-entrypoint && \
    chmod +x /usr/local/bin/agent-entrypoint

# 4. Non-root user (UID configurable so the 0600 /auth creds are readable).
ARG HOST_UID=1000
RUN useradd -ms /bin/bash -u ${HOST_UID} agentdev
USER agentdev
WORKDIR /home/agentdev

# 4b. npm global prefix in $HOME so `npm i -g` works as non-root; ensure ~/.claude.
RUN npm config set prefix /home/agentdev/.local && mkdir -p /home/agentdev/.claude

# 5. Coding-agent CLIs (user-space).
#    Claude Code — honors HTTP(S)_PROXY; auth via copied creds or CLAUDE_CODE_OAUTH_TOKEN.
RUN curl -fsSL https://claude.ai/install.sh | bash
#    herdr — firstmate's agent-native terminal multiplexer backend (herdr.dev).
RUN curl -fsSL https://herdr.dev/install.sh | sh || echo "WARN: herdr install failed (best-effort)"
#    Antigravity CLI (agy) — BEST-EFFORT: documented to ignore HTTP(S)_PROXY on Linux,
#    self-updates, and uses a keyring the container lacks. May not work behind Squid.
RUN curl -fsSL https://antigravity.google/cli/install.sh | bash || echo "WARN: antigravity (agy) install failed (best-effort)"

# 6. firstmate — cloned from the CONFIGURED fork (Settings/wizard sets FIRSTMATE_REPO;
#    default: the user's), defaulted to the herdr backend + claude harness.
ARG FIRSTMATE_REPO=https://github.com/Marl0nL/firstmate.git
RUN git clone --depth 1 "$FIRSTMATE_REPO" /home/agentdev/firstmate && \
    mkdir -p /home/agentdev/firstmate/config && \
    printf 'herdr\n' > /home/agentdev/firstmate/config/backend && \
    printf 'claude\n' > /home/agentdev/firstmate/config/crew-harness
# 6b. firstmate bootstrap toolchain (best-effort; fm-bootstrap reports any that are missing).
RUN curl -fsSL https://kunchenguid.github.io/treehouse/install.sh | sh || echo "WARN: treehouse install failed" ; \
    curl -fsSL https://raw.githubusercontent.com/kunchenguid/no-mistakes/main/docs/install.sh | sh || echo "WARN: no-mistakes install failed"
RUN npm install -g gh-axi chrome-devtools-axi lavish-axi tasks-axi quota-axi || echo "WARN: *-axi npm install failed" ; \
    for t in gh-axi chrome-devtools-axi lavish-axi; do "$t" setup hooks >/dev/null 2>&1 || true; done

# 7. Optional base Python deps.
COPY --chown=agentdev:agentdev requirements.txt .
RUN pip install --no-cache-dir --user -r requirements.txt

# 8. Client commands + skills LAST, so iterating on them is a cheap rebuild.
USER root
COPY agent-bin/ /usr/local/bin/
RUN chmod +x /usr/local/bin/request-domain /usr/local/bin/request-command \
             /usr/local/bin/refresh-daily-auth /usr/local/bin/await-request \
             /usr/local/bin/install-flutter /usr/local/bin/install-adb \
             /usr/local/bin/firstmate-herdr
# Auto-auth Claude Code from the mounted, rotatable token file (auth/claude-token):
# every login shell (the quick-start runs `bash -lc`) re-reads the LIVE mount and
# synthesizes ~/.claude/.credentials.json from it, so a rotated token reaches new
# sessions without recreating the container. (See container/claude-login.sh.)
COPY container/claude-login.sh /etc/profile.d/claude-token.sh
USER agentdev
COPY --chown=agentdev:agentdev skills/ /home/agentdev/.claude/skills/

# Pre-seed ~/.claude.json so `claude` boots straight into work with no prompts:
#   hasCompletedOnboarding            -> skips the first-run theme/onboarding flow
#   bypassPermissionsModeAccepted     -> skips the --dangerously-skip-permissions
#                                        warning firstmate's own claude launch hits
#   hasAcknowledgedCostThreshold      -> skips the spend-threshold notice
#   projects[/home/agentdev/firstmate] hasTrustDialogAccepted / *ProjectOnboarding
#                                     -> skips the per-project trust + onboarding
# (claude merges its own runtime keys in on first run; these survive.)
RUN printf '%s' '{"hasCompletedOnboarding":true,"bypassPermissionsModeAccepted":true,"hasAcknowledgedCostThreshold":true,"theme":"dark","projects":{"/home/agentdev/firstmate":{"hasTrustDialogAccepted":true,"hasCompletedProjectOnboarding":true,"projectOnboardingSeenCount":1,"allowedTools":[],"mcpServers":{},"enabledMcpjsonServers":[],"disabledMcpjsonServers":[],"hasClaudeMdExternalIncludesApproved":false,"hasClaudeMdExternalIncludesWarningShown":false}}}' > /home/agentdev/.claude.json

# Activate injected creds on start, then keep the container alive for firstmate.
ENTRYPOINT ["/usr/local/bin/agent-entrypoint"]
CMD ["tail", "-f", "/dev/null"]
