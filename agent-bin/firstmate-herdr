#!/usr/bin/env bash
# Launch the firstmate PRIMARY (claude) inside a persistent herdr workspace, so the
# primary session and the crewmates firstmate spawns (backend=herdr) share one visible,
# attachable workspace.
#
# Strategy (validated against herdr 0.7.3): ATTACH FIRST, then inject claude into the
# LIVE session from a detached helper. Pre-creating the agent headless and then attaching
# is racy — the attaching client "adopts" a still-initializing agent pane and can drop it.
# Adding claude AFTER the client is attached avoids that entirely.
#
# The helper: waits for the attach to bring the server + default workspace up, launches
# claude as a real agent process (`agent start` — no shell-typing race), and moves it to
# its own full-screen tab (the attach's shell stays as tab 1). If a firstmate primary is
# already present (re-attach), it does nothing (no duplicate).
set -u

SESSION="${FM_HERDR_SESSION:-firstmate}"
FMDIR="${FM_DIR:-$HOME/firstmate}"
PROMPT="${FM_PROMPT:-${1:-Ahoy firstmate, get yourself oriented and ready to work.}}"

if [ "${FM_INJECT:-}" = 1 ]; then
  # --- detached injector: add claude to the attached session ---
  for _ in $(seq 1 80); do
    herdr --session "$SESSION" status server >/dev/null 2>&1 && break
    sleep 0.25
  done
  # already have a primary (re-attach)? leave it alone
  herdr --session "$SESSION" agent list 2>/dev/null | grep -q '"name":"firstmate"' && exit 0
  # Launch claude, RETRYING against the attach-adoption race (herdr occasionally drops a
  # freshly-started agent pane while the client is still settling). Each attempt starts
  # claude, waits, and only keeps it (moves to its own tab) once it's confirmed present.
  for attempt in 1 2 3 4 5; do
    wsid="$(herdr --session "$SESSION" workspace list 2>/dev/null \
            | jq -r '.result.workspaces[0].workspace_id // empty' 2>/dev/null)"
    if [ -n "$wsid" ]; then
      out="$(herdr --session "$SESSION" agent start firstmate --workspace "$wsid" --cwd "$FMDIR" --focus \
               -- claude --permission-mode auto "$PROMPT" 2>/dev/null)"
      apane="$(printf '%s' "$out" | jq -r '.result.agent.pane_id // empty' 2>/dev/null)"
      if [ -n "$apane" ]; then
        sleep 1.5
        if herdr --session "$SESSION" agent list 2>/dev/null | grep -q '"name":"firstmate"'; then
          herdr --session "$SESSION" pane move "$apane" --new-tab --label firstmate --focus >/dev/null 2>&1
          exit 0
        fi
      fi
    fi
    sleep 1
  done
  exit 0
fi

# --- main: launch the injector detached, then attach (the attach starts the server) ---
cd "$FMDIR" 2>/dev/null || true

# Ensure herdr's first-run onboarding modal is OFF before attaching. It blocks the default
# workspace from being created until dismissed, which starves the claude injector (it times
# out waiting for a workspace). Done at runtime too (not just baked) so it also covers
# snapshot images that predate the bake. Idempotent.
mkdir -p "$HOME/.config/herdr"
grep -qs '^onboarding' "$HOME/.config/herdr/config.toml" 2>/dev/null || \
  printf 'onboarding = false\n' >> "$HOME/.config/herdr/config.toml"

FM_INJECT=1 FM_HERDR_SESSION="$SESSION" FM_DIR="$FMDIR" FM_PROMPT="$PROMPT" \
  setsid "$0" >/dev/null 2>&1 &
exec herdr --session "$SESSION"
