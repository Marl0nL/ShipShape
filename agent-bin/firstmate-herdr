#!/usr/bin/env bash
# Launch the firstmate PRIMARY (claude) inside a persistent herdr workspace, so the
# primary session and the crewmates firstmate spawns (backend=herdr) share one
# visible, attachable workspace.
#
# Sequence (validated against herdr 0.7.3):
#   1. ensure a headless herdr server for the session
#   2. on a FRESH session, create the primary workspace and `pane run` claude in it
#   3. attach the interactive workspace (the foreground TUI the operator sees)
# Re-running against an already-live session just re-attaches (no duplicate primary).
set -u

SESSION="${FM_HERDR_SESSION:-firstmate}"
FMDIR="${FM_DIR:-$HOME/firstmate}"
PROMPT="${1:-Ahoy firstmate, get yourself oriented and ready to work.}"

cd "$FMDIR" 2>/dev/null || true

fresh=1
if herdr --session "$SESSION" status server >/dev/null 2>&1; then
  fresh=0                                   # already running -> reattach, don't duplicate
else
  herdr --session "$SESSION" server >/dev/null 2>&1 &
  for _ in $(seq 1 40); do
    herdr --session "$SESSION" status server >/dev/null 2>&1 && break
    sleep 0.25
  done
fi

if [ "$fresh" = 1 ]; then
  pane="$(herdr --session "$SESSION" workspace create --cwd "$FMDIR" --label firstmate 2>/dev/null \
          | jq -r '.result.root_pane.pane_id // empty' 2>/dev/null)"
  if [ -n "$pane" ]; then
    herdr --session "$SESSION" pane run "$pane" \
      "claude --permission-mode auto \"$PROMPT\"" >/dev/null 2>&1 || true
  fi
fi

exec herdr --session "$SESSION"
