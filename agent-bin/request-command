#!/bin/sh
# Propose a host command for operator review, then BLOCK until accepted/declined.
# On acceptance the returned JSON carries the command's exit status + output.
set -eu
BROKER="${SHIPSHAPE_BROKER:-http://control-plane:8099}"
[ $# -ge 1 ] || { echo 'usage: request-command "<command>" [reason]' >&2; exit 2; }
payload=$(python3 -c 'import json,sys; print(json.dumps({"command":sys.argv[1],"reason":sys.argv[2] if len(sys.argv)>2 else ""}))' "$@")
resp=$(curl -fsS -X POST "$BROKER/request-command" -H 'Content-Type: application/json' -d "$payload")
id=$(printf '%s' "$resp" | python3 -c 'import json,sys
try: print(json.load(sys.stdin).get("id",""))
except Exception: print("")')
[ -n "$id" ] || { echo "$resp"; exit 1; }
echo "proposed command (id $id) — waiting for operator review…"
exec await-request "$id"
