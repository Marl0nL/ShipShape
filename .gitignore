# Credentials — NEVER commit
.env
.env.*
!.env.example
auth/*
!auth/README.md

# Control-plane runtime state and IPC spool
control-plane/spool/
control-plane/state/

# Persistent agent working data
firstmate-data/

# Local config — personal, must NOT be inherited by other installs. Seeded on first
# run from the tracked *.example templates; edit the live files locally.
/shipshape.toml
egress/allowed_domains.txt

# Control-plane backups
egress/*.bak

# Python
__pycache__/
*.pyc
control-plane/.venv/
control-plane/*.egg-info/
control-plane/build/
control-plane/dist/
