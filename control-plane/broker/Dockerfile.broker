# ShipShape in-container broker — stdlib only, non-root, no credentials.
FROM python:3.12-slim@sha256:423ed6ab25b1921a477529254bfeeabf5855151dc2c3141699a1bfc852199fbf

RUN useradd -m broker
COPY broker.py /app/broker.py
USER broker

ENV SHIPSHAPE_SPOOL=/spool
ENV SHIPSHAPE_BROKER_PORT=8099
EXPOSE 8099

CMD ["python3", "/app/broker.py"]
